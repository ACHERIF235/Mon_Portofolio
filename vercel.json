{
    "functions": {
        "**/*.php": {
            "runtime": "vercel-php@0.9.2"
        }
    },
    "routes": [
        {
            "src": "/admin/(.*\\.php)",
            "dest": "/admin/$1"
        },
        {
            "src": "/admin/.*",
            "dest": "/admin/index.php"
        },
        {
            "src": "/assets/(.*)",
            "dest": "/assets/$1"
        },
        {
            "src": "/(.*\\.php)",
            "dest": "/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/index.php"
        }
    ]
}
